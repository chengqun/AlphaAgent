{
  "App": {
    "SelfUrl": "https://localhost:44319",
    "RedirectAllowedUrls": "https://localhost:44319"
  },
  "ConnectionStrings": {
    "Default": "${CONNECTION_STRING}"
  },
  "AuthServer": {
    "Authority": "https://localhost:44319",
    "RequireHttpsMetadata": false
  },
  "StringEncryption": {
    "DefaultPassPhrase": "${PASSPHRASE}"
  },
  "OpenIddict": {
    "Applications": {
      "AlphaAgent_Chat": {
        "ClientId": "alphaagent_chat",
        "ClientSecret": "${CLIENT_SECRET}"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "VersionConfig": {
    "PublishToken": "${VERSION_PUBLISH_TOKEN}"
  }
}
