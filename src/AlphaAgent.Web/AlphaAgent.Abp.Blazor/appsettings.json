{
  "App": {
    "SelfUrl": "https://localhost:44333",
    "RedirectAllowedUrls": "https://localhost:44333"
  },
  "ConnectionStrings": {
    "Default": "${CONNECTION_STRING}"
  },
  "AuthServer": {
    "Authority": "https://localhost:44333",
    "RequireHttpsMetadata": false
  },
  "StringEncryption": {
    "DefaultPassPhrase": "${PASSPHRASE}"
  },
  "OpenIddict": {
    "Applications": {
      "AlphaAgent_Chat": {
        "ClientId": "alphaagent_chat",
        "ClientSecret": "${CLIENT_SECRET}"
      }
    }
  },
  "SecuritySync": {
    "Url": "",
    "IntervalMinutes": 1440
  },
  "VersionConfig": {
    "PublishToken": "${VERSION_PUBLISH_TOKEN}"
  }
}