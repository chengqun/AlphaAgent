@page "/version-config-management"
@inherits AbpComponentBase
@using AlphaAgent.Abp.Application.Contracts.DTOs.VersionConfig
@using AlphaAgent.Abp.Application.Contracts.Services.VersionConfig
@using AlphaAgent.Abp.Domain.Shared.Enums
@inject IVersionConfigAppService VersionConfigAppService
@inject IJSRuntime JS

<PageTitle>应用版本管理</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">应用版本管理</h2>
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-control form-control-sm" style="width:140px;" @bind="filterPlatform" @bind:event="onchange">
                        <option value="-1">全部平台</option>
                        <option value="0">iOS</option>
                        <option value="1">Android</option>
                        <option value="2">Windows</option>
                        <option value="3">MacCatalyst</option>
                    </select>
                    <button type="button" class="btn btn-primary" @onclick="ShowCreateModal">
                        <i class="fas fa-plus"></i> 新增版本
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 版本列表 -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border" role="status">
                                <span class="sr-only">加载中...</span>
                            </div>
                        </div>
                    }
                    else if (versionConfigs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>平台</th>
                                        <th>版本号</th>
                                        <th>版本名</th>
                                        <th>下载地址</th>
                                        <th>更新说明</th>
                                        <th>强制更新</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var config in versionConfigs)
                                    {
                                        <tr>
                                            <td>@GetPlatformName(config.Platform)</td>
                                            <td>@config.VersionCode</td>
                                            <td>@config.VersionName</td>
                                            <td>
                                                <a href="@config.UpdateUrl" target="_blank" style="max-width:200px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@config.UpdateUrl">@config.UpdateUrl</a>
                                            </td>
                                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@config.UpdateNote">@config.UpdateNote</td>
                                            <td>
                                                @if (config.IsForce)
                                                {
                                                    <span class="badge badge-danger">强制</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">可选</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-warning me-1" @onclick="() => ShowEditModal(config)">编辑</button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteVersionConfig(config)">删除</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <!-- 分页 -->
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <small class="text-muted">共 @totalCount 条记录，第 @currentPage / @totalPages 页</small>
                            <div class="d-flex align-items-center gap-1">
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => GoToPage(1)" disabled="@(currentPage <= 1)">首页</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(currentPage <= 1)">上一页</button>
                                @foreach (var p in GetPageNumbers())
                                {
                                    if (p < 0)
                                    {
                                        <span class="px-1 text-muted">…</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn @(p == currentPage ? "btn-primary" : "btn-outline-secondary") btn-sm" @onclick="() => GoToPage(p)">@p</button>
                                    }
                                }
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(currentPage >= totalPages)">下一页</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => GoToPage(totalPages)" disabled="@(currentPage >= totalPages)">末页</button>
                                <span class="mx-1 text-muted">跳至</span>
                                <input type="number" class="form-control form-control-sm" style="width:60px;" @bind="jumpPage" min="1" max="@totalPages" placeholder="页码" />
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => GoToPage(jumpPage)">确定</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-mobile-alt" style="font-size: 48px;"></i>
                            <p class="mt-3">暂无版本配置数据</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增/编辑 Modal -->
<div class="modal" tabindex="-1" role="dialog" style="display: @(showModal ? "block" : "none");" @onclick="CloseModal">
    <div class="modal-dialog" role="document" @onclick:stopPropagation>
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(isEditing ? "编辑版本配置" : "新增版本配置")</h5>
                <button type="button" class="close" aria-label="Close" @onclick="CloseModal">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>平台</label>
                    <select class="form-control" @bind="editingPlatformInt">
                        <option value="0">iOS</option>
                        <option value="1">Android</option>
                        <option value="2">Windows</option>
                        <option value="3">MacCatalyst</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>版本号 (VersionCode)</label>
                    <input type="number" class="form-control" @bind="editingConfig.VersionCode" placeholder="递增数字，如 10" />
                </div>
                <div class="form-group">
                    <label>版本名 (VersionName)</label>
                    <input type="text" class="form-control" @bind="editingConfig.VersionName" placeholder="如 2.1.0" />
                </div>
                <div class="form-group">
                    <label>下载地址</label>
                    <input type="text" class="form-control" @bind="editingConfig.UpdateUrl" placeholder="下载链接" />
                </div>
                <div class="form-group">
                    <label>更新说明</label>
                    <textarea class="form-control" @bind="editingConfig.UpdateNote" rows="4" placeholder="更新内容描述"></textarea>
                </div>
                <div class="form-group">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="editingConfig.IsForce" />
                        <label class="form-check-label">强制更新</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal">取消</button>
                <button type="button" class="btn btn-primary" @onclick="SaveVersionConfig" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
}
