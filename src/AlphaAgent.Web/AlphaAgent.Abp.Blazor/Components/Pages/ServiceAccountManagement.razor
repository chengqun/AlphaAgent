@page "/service-account-management"
@inherits AbpComponentBase
@using AlphaAgent.Abp.Application.Contracts.DTOs.ServiceAccounts
@using AlphaAgent.Abp.Application.Contracts.Services.ServiceAccounts
@inject IServiceAccountAppService ServiceAccountAppService
@inject IJSRuntime JS

<PageTitle>服务号管理</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">服务号管理</h2>
                <button type="button" class="btn btn-primary" @onclick="ShowCreateModal">
                    <i class="fas fa-plus"></i> 新增服务号
                </button>
            </div>
        </div>
    </div>

    <!-- 服务号列表 -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border" role="status">
                                <span class="sr-only">加载中...</span>
                            </div>
                        </div>
                    }
                    else if (serviceAccounts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>名称</th>
                                        <th>分类</th>
                                        <th>简介</th>
                                        <th>认证</th>
                                        <th>关注者</th>
                                        <th>创建时间</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sa in serviceAccounts)
                                    {
                                        <tr>
                                            <td>
                                                @sa.Name
                                                @if (sa.IsVerified)
                                                {
                                                    <i class="fas fa-check-circle text-primary" title="已认证"></i>
                                                }
                                            </td>
                                            <td><span class="badge bg-info">@sa.Category</span></td>
                                            <td>@(sa.Description?.Length > 30 ? sa.Description[..30] + "..." : sa.Description)</td>
                                            <td>@(sa.IsVerified ? "✓" : "—")</td>
                                            <td>@sa.FollowerCount</td>
                                            <td>@sa.CreationTime.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-success me-1" @onclick="() => ShowPublishModal(sa)">发内容</button>
                                                <button type="button" class="btn btn-sm btn-outline-warning me-1" @onclick="() => ShowEditModal(sa)">编辑</button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteServiceAccount(sa)">删除</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-bullhorn" style="font-size: 48px;"></i>
                            <p class="mt-3">暂无服务号</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增/编辑 Modal -->
<div class="modal" tabindex="-1" role="dialog" style="display: @(showModal ? "block" : "none");" @onclick="CloseModal">
    <div class="modal-dialog" role="document" @onclick:stopPropagation>
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(isEditing ? "编辑服务号" : "新增服务号")</h5>
                <button type="button" class="close" aria-label="Close" @onclick="CloseModal">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>名称</label>
                    <input type="text" class="form-control" @bind="editingItem.Name" placeholder="服务号名称" />
                </div>
                <div class="form-group">
                    <label>分类</label>
                    <select class="form-control" @bind="editingItem.Category">
                        <option value="资讯">资讯</option>
                        <option value="投研">投研</option>
                        <option value="策略">策略</option>
                        <option value="工具">工具</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>头像 URL</label>
                    <input type="text" class="form-control" @bind="editingItem.AvatarUrl" placeholder="头像图片地址" />
                </div>
                <div class="form-group">
                    <label>简介</label>
                    <textarea class="form-control" @bind="editingItem.Description" rows="3" placeholder="服务号简介"></textarea>
                </div>
                <div class="form-group">
                    <label>欢迎语</label>
                    <textarea class="form-control" @bind="editingItem.WelcomeMessage" rows="2" placeholder="用户关注后的欢迎消息"></textarea>
                </div>
                @if (isEditing)
                {
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" @bind="editingItem.IsVerified" />
                            <label class="form-check-label">已认证</label>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal">取消</button>
                <button type="button" class="btn btn-primary" @onclick="SaveServiceAccount" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 发内容 Modal -->
<div class="modal" tabindex="-1" role="dialog" style="display: @(showPostModal ? "block" : "none");" @onclick="ClosePostModal">
    <div class="modal-dialog modal-lg" role="document" @onclick:stopPropagation>
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">为 @postServiceAccountName 发布内容</h5>
                <button type="button" class="close" aria-label="Close" @onclick="ClosePostModal">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>标题</label>
                    <input type="text" class="form-control" @bind="postTitle" placeholder="内容标题" />
                </div>
                <div class="form-group">
                    <label>内容类型</label>
                    <select class="form-control" @bind="postContentType">
                        <option value="Article">文章</option>
                        <option value="Analysis">分析</option>
                        <option value="Alert">提醒</option>
                        <option value="Link">链接</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>摘要</label>
                    <textarea class="form-control" @bind="postSummary" rows="2" placeholder="内容摘要（可选）"></textarea>
                </div>
                <div class="form-group">
                    <label>正文</label>
                    <textarea class="form-control" @bind="postContent" rows="8" placeholder="正文内容（支持 Markdown）"></textarea>
                </div>
                <div class="form-group">
                    <label>封面图 URL</label>
                    <input type="text" class="form-control" @bind="postCoverImageUrl" placeholder="封面图片地址（可选）" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="ClosePostModal">取消</button>
                <button type="button" class="btn btn-primary" @onclick="PublishPost" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                    }
                    else
                    {
                        <span>发布</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@if (showModal || showPostModal)
{
    <div class="modal-backdrop fade show"></div>
}