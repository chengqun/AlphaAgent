<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlphaAgent.Maui"
             xmlns:converters="clr-namespace:AlphaAgent.Maui.Converters"
             x:Class="AlphaAgent.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- 转换器 -->
            <converters:NullToBooleanConverter x:Key="NullToBooleanConverter" />
            <converters:BooleanToColorConverter x:Key="BooleanToColorConverter" />
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:RoleToBoolConverter x:Key="RoleToBoolConverter" />
            <converters:UtcToLocalTimeConverter x:Key="UtcToLocalTimeConverter" />
            <converters:IntEqualsConverter x:Key="IntEqualsConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
