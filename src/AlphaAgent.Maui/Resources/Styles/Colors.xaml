<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ================================================================ -->
    <!--  极简双主题 — Apple HIG                                            -->
    <!--  Light: #FFFFFF 纯白 + #000000 纯黑                                -->
    <!--  Dark:  #000000 纯黑 + #1C1C1E 系统灰提升面                        -->
    <!--  品牌色: #C9A227                                                   -->
    <!-- ================================================================ -->

    <!-- ========== 品牌色 ========== -->
    <Color x:Key="Primary">#C9A227</Color>
    <Color x:Key="PrimaryLight">#F5E6B8</Color>
    <Color x:Key="Secondary">#8E8E93</Color>

    <!-- ========== 背景 ========== -->
    <Color x:Key="AppBackgroundLight">#FFFFFF</Color>
    <Color x:Key="AppBackgroundDark">#000000</Color>

    <Color x:Key="PageBackgroundLight">#FFFFFF</Color>
    <Color x:Key="PageBackgroundDark">#000000</Color>

    <Color x:Key="CardBackgroundLight">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1C1C1E</Color>

    <!-- ========== 文字 ========== -->
    <Color x:Key="TextPrimaryLight">#000000</Color>
    <Color x:Key="TextPrimaryDark">#FFFFFF</Color>

    <Color x:Key="TextSecondaryLight">#3C3C43</Color>
    <Color x:Key="TextSecondaryDark">#8E8E93</Color>

    <Color x:Key="TextTertiaryLight">#8E8E93</Color>
    <Color x:Key="TextTertiaryDark">#636366</Color>

    <Color x:Key="TextWhite">#FFFFFF</Color>
    <Color x:Key="TextError">#FF3B30</Color>

    <!-- ========== 边框 & 分隔线 ========== -->
    <Color x:Key="BorderLight">#C6C6C8</Color>
    <Color x:Key="BorderDark">#38383A</Color>

    <Color x:Key="SeparatorLight">#E5E5EA</Color>
    <Color x:Key="SeparatorDark">#2C2C2E</Color>

    <!-- ========== 按钮 ========== -->
    <Color x:Key="ButtonPrimaryBackground">#C9A227</Color>
    <Color x:Key="ButtonPrimaryText">#000000</Color>
    <Color x:Key="ButtonSecondaryBackgroundLight">#F5E6B8</Color>
    <Color x:Key="ButtonSecondaryBackgroundDark">#2C2C2E</Color>
    <Color x:Key="ButtonSecondaryText">#C9A227</Color>

    <!-- ========== 状态色 ========== -->
    <Color x:Key="SuccessColor">#34C759</Color>
    <Color x:Key="WarningColor">#C9A227</Color>
    <Color x:Key="ErrorColor">#FF3B30</Color>
    <Color x:Key="InfoColor">#007AFF</Color>

    <!-- ========== 消息气泡 ========== -->
    <Color x:Key="ReceivedMessageBackgroundLight">#E5E5EA</Color>
    <Color x:Key="ReceivedMessageBackgroundDark">#2C2C2E</Color>

    <Color x:Key="SentMessageBackgroundLight">#C9A227</Color>
    <Color x:Key="SentMessageBackgroundDark">#C9A227</Color>
    <Color x:Key="SentMessageTextColorLight">#000000</Color>
    <Color x:Key="SentMessageTextColorDark">#000000</Color>
    <Color x:Key="SentMessageTimeColorLight">#5A4A1E</Color>
    <Color x:Key="SentMessageTimeColorDark">#000000</Color>

    <!-- ========== AI 助手消息 ========== -->
    <Color x:Key="AssistantMessageBackgroundLight">#E8F0FE</Color>
    <Color x:Key="AssistantMessageBackgroundDark">#1C2D4A</Color>
    <Color x:Key="AssistantMessageTextLight">#000000</Color>
    <Color x:Key="AssistantMessageTextDark">#D4E3F5</Color>

    <!-- ========== 工具调用 ========== -->
    <Color x:Key="ToolCallBackgroundLight">#E8F0FE</Color>
    <Color x:Key="ToolCallBackgroundDark">#1A2A40</Color>
    <Color x:Key="ToolCallTextLight">#0055CC</Color>
    <Color x:Key="ToolCallTextDark">#6EA8FE</Color>
    <Color x:Key="ToolCallText">#0055CC</Color>
    <Color x:Key="ToolResultBackgroundLight">#E6F9E6</Color>
    <Color x:Key="ToolResultBackgroundDark">#1A2E1A</Color>
    <Color x:Key="ToolResultTextLight">#1B7A1B</Color>
    <Color x:Key="ToolResultTextDark">#6FCF6F</Color>
    <Color x:Key="ToolResultText">#1B7A1B</Color>

    <!-- ========== 错误提示 ========== -->
    <Color x:Key="ErrorBackgroundLight">#FFE5E5</Color>
    <Color x:Key="ErrorBackgroundDark">#2A1010</Color>
    <Color x:Key="ErrorTextLight">#FF3B30</Color>
    <Color x:Key="ErrorTextDark">#FF6B6B</Color>
    <Color x:Key="ErrorText">#FF3B30</Color>

    <!-- ========== 头像 ========== -->
    <Color x:Key="AvatarBackgroundLight">#007AFF</Color>
    <Color x:Key="AvatarBackgroundDark">#0A84FF</Color>

    <!-- ========== 视频页（始终深色） ========== -->
    <Color x:Key="VideoPageBackgroundLight">#000000</Color>
    <Color x:Key="VideoPageBackgroundDark">#000000</Color>
    <Color x:Key="VideoRetryBackgroundLight">#2C2C2E</Color>
    <Color x:Key="VideoRetryBackgroundDark">#2C2C2E</Color>

    <!-- ========== Markdown ========== -->
    <Color x:Key="MarkdownCodeBackgroundLight">#F2F2F7</Color>
    <Color x:Key="MarkdownCodeBackgroundDark">#2C2C2E</Color>
    <Color x:Key="MarkdownCodeTextLight">#000000</Color>
    <Color x:Key="MarkdownCodeTextDark">#EBEBF5</Color>
    <Color x:Key="MarkdownCodeBorderLight">#C6C6C8</Color>
    <Color x:Key="MarkdownCodeBorderDark">#48484A</Color>

    <Color x:Key="MarkdownBlockQuoteBackgroundLight">#EAF4FC</Color>
    <Color x:Key="MarkdownBlockQuoteBackgroundDark">#1C3048</Color>
    <Color x:Key="MarkdownBlockQuoteTextLight">#3C3C43</Color>
    <Color x:Key="MarkdownBlockQuoteTextDark">#8E8E93</Color>

    <Color x:Key="MarkdownHyperlinkLight">#007AFF</Color>
    <Color x:Key="MarkdownHyperlinkDark">#0A84FF</Color>
    <Color x:Key="MarkdownHeadingLight">#000000</Color>
    <Color x:Key="MarkdownHeadingDark">#FFFFFF</Color>
    <Color x:Key="MarkdownLineLight">#C6C6C8</Color>
    <Color x:Key="MarkdownLineDark">#38383A</Color>

    <!-- ========== 灰度 ========== -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#F2F2F7</Color>
    <Color x:Key="Gray200">#E5E5EA</Color>
    <Color x:Key="Gray300">#C7C7CC</Color>
    <Color x:Key="Gray400">#8E8E93</Color>
    <Color x:Key="Gray500">#636366</Color>
    <Color x:Key="Gray600">#48484A</Color>
    <Color x:Key="Gray900">#2C2C2E</Color>
    <Color x:Key="Gray950">#1C1C1E</Color>
    <Color x:Key="MidnightBlue">#007AFF</Color>

</ResourceDictionary>
