<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ================================================================ -->
    <!--  命名规则：                                                        -->
    <!--  语义色（随主题切换）：{Name} + {Name}Light + {Name}Dark           -->
    <!--  静态色（不随主题切换）：{Name}，无 Light/Dark 变体                  -->
    <!--  未来换肤只需改本文件，所有页面通过 Style/Resource 引用              -->
    <!-- ================================================================ -->

    <!-- ========== 主色调 ========== -->
    <Color x:Key="Primary">#C9A227</Color>
    <Color x:Key="PrimaryLight">#F5E6B8</Color>
    <Color x:Key="PrimaryDark">#F5E6B8</Color>

    <!-- ========== 辅色 ========== -->
    <Color x:Key="Secondary">#8B7355</Color>
    <Color x:Key="SecondaryLight">#D4C4A8</Color>
    <Color x:Key="SecondaryDark">#5C4B32</Color>

    <!-- ========== 应用背景 ========== -->
    <Color x:Key="AppBackgroundLight">#FDFBF7</Color>
    <Color x:Key="AppBackgroundDark">#0F0F1A</Color>
    <Color x:Key="AppBackground">#FDFBF7</Color>

    <!-- ========== 页面背景 ========== -->
    <Color x:Key="PageBackgroundLight">#F9F6F0</Color>
    <Color x:Key="PageBackgroundDark">#12121F</Color>
    <Color x:Key="PageBackground">#F9F6F0</Color>

    <!-- ========== 卡片背景 ========== -->
    <Color x:Key="CardBackgroundLight">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1A1A2E</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <!-- ========== 文字颜色 ========== -->
    <Color x:Key="TextPrimaryLight">#1A1A1A</Color>
    <Color x:Key="TextPrimaryDark">#E8E0D5</Color>
