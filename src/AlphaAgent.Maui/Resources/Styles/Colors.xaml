    <Color x:Key="SuccessColor">#2E7D32</Color>
    <Color x:Key="WarningColor">#C9A227</Color>
    <Color x:Key="ErrorColor">#C41E3A</Color>
    <Color x:Key="InfoColor">#1E88E5</Color>

