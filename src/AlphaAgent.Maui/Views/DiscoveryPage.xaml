<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlphaAgent.Maui.Views.DiscoveryPage"
             Title="发现"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
        <StackLayout>
            <!-- 朋友圈入口 -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}" 
                    StrokeShape="RoundRectangle 12"
                    Padding="{StaticResource CardPadding}" 
                    Margin="0,0,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToMomentsCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                    <Image Grid.Column="0" Source="moments" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="1" Text="朋友圈" FontSize="16" Style="{StaticResource LabelPrimary}" Margin="12,0,0,0" />
                    <Image Grid.Column="2" Source="right_arrow" WidthRequest="16" HeightRequest="16" />
                </Grid>
            </Border>
            
            <!-- 视频号入口 -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                    StrokeShape="RoundRectangle 12"
                    Padding="{StaticResource CardPadding}"
                    Margin="0,1,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToVideoChannelsCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                    <Image Grid.Column="0" Source="video" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="1" Text="视频号" FontSize="16" Style="{StaticResource LabelPrimary}" Margin="12,0,0,0" />
                    <Image Grid.Column="2" Source="right_arrow" WidthRequest="16" HeightRequest="16" />
                </Grid>
            </Border>
        </StackLayout>
    </ScrollView>

</ContentPage>
