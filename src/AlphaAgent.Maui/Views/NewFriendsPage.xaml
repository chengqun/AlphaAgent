<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlphaAgent.Maui.Views"
             x:Class="AlphaAgent.Maui.Views.NewFriendsPage"
             Title="新的朋友"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
             Appearing="OnAppearing"
             Shell.TabBarIsVisible="False">
    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
        <StackLayout Padding="{StaticResource SectionPadding}" Spacing="{StaticResource SpacingSmall}">
            <!-- 状态消息 -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="{StaticResource ErrorColor}"
                   FontSize="14"
                   Margin="0,8,0,0"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource NullToBooleanConverter}}" />

            <!-- 待处理请求列表 -->
            <CollectionView ItemsSource="{Binding PendingRequests}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}" Margin="0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout>
                            <Grid Padding="{StaticResource ListItemPadding}" ColumnDefinitions="Auto,*,Auto">
                                <!-- 头像 -->
                                <Grid Grid.Column="0" Margin="0,0,16,0">
                                    <Border
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource AvatarBackgroundLight}, Dark={StaticResource AvatarBackgroundDark}}">
                                        <Grid WidthRequest="56" HeightRequest="56">
                                            <Label
                                                Text="{Binding Initial}"
                                                FontSize="22"
                                                FontAttributes="Bold"
                                                HorizontalTextAlignment="Center"
                                                VerticalTextAlignment="Center"
                                                TextColor="{StaticResource TextWhite}"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- 信息 -->
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto">
                                    <Label
                                        Grid.Row="0"
                                        Text="{Binding Name}"
                                        Style="{StaticResource LabelPrimary}"
                                        FontAttributes="Bold" />
                                    <Label
                                        Grid.Row="1"
                                        Text="{Binding Type}"
                                        Style="{StaticResource LabelSecondary}" />
                                    <Label
                                        Grid.Row="2"
                                        Text="{Binding CreatedAt}"
                                        Style="{StaticResource LabelTertiary}" />
                                </Grid>

                                <!-- 操作按钮 -->
                                <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                    <Button
                                        Grid.Column="0"
                                        Text="接受"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextWhite}"
                                        BackgroundColor="{StaticResource InfoColor}"
                                        CornerRadius="6"
                                        HeightRequest="32"
                                        WidthRequest="64"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:NewFriendsPage}}, Path=BindingContext.AcceptRequestCommand}"
                                        CommandParameter="{Binding}" />
                                    <Button
                                        Grid.Column="1"
                                        Text="拒绝"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource AppBackgroundLight}, Dark={StaticResource AppBackgroundDark}}"
                                        CornerRadius="6"
                                        HeightRequest="32"
                                        WidthRequest="64"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:NewFriendsPage}}, Path=BindingContext.RejectRequestCommand}"
                                        CommandParameter="{Binding}" />
                                </Grid>
                            </Grid>

                            <!-- 分割线 -->
                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource SeparatorLight}, Dark={StaticResource SeparatorDark}}" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ScrollView>
</ContentPage>
