<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlphaAgent.Maui.Views.ServiceAccountBrowsePage"
             Title="服务号"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- 搜索栏 -->
        <Grid Grid.Row="0" Padding="{StaticResource PagePadding}" ColumnDefinitions="*, Auto">
            <Entry Grid.Column="0"
                   Text="{Binding SearchText}"
                   Placeholder="搜索服务号"
                   ReturnType="Search"
                   ReturnCommand="{Binding SearchCommand}" />
            <Button Grid.Column="1"
                    Text="搜索"
                    Command="{Binding SearchCommand}"
                    Margin="8,0,0,0" />
        </Grid>

        <!-- 分类筛选 -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" Padding="{StaticResource PagePadding}">
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Button Text="全部" Command="{Binding FilterByCategoryCommand}" CommandParameter="全部" />
                <Button Text="财经" Command="{Binding FilterByCategoryCommand}" CommandParameter="财经" />
                <Button Text="科技" Command="{Binding FilterByCategoryCommand}" CommandParameter="科技" />
                <Button Text="生活" Command="{Binding FilterByCategoryCommand}" CommandParameter="生活" />
                <Button Text="教育" Command="{Binding FilterByCategoryCommand}" CommandParameter="教育" />
                <Button Text="娱乐" Command="{Binding FilterByCategoryCommand}" CommandParameter="娱乐" />
                <Button Text="健康" Command="{Binding FilterByCategoryCommand}" CommandParameter="健康" />
            </StackLayout>
        </ScrollView>

        <!-- 服务号列表 -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding ServiceAccounts}" Margin="0,8,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                            StrokeShape="RoundRectangle 12"
                            Margin="8,0,8,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="{StaticResource CardPadding}">
                            <!-- 头像 -->
                            <Border Grid.Column="0" WidthRequest="48" HeightRequest="48"
                                    StrokeShape="RoundRectangle 24"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource AvatarBackgroundLight}, Dark={StaticResource AvatarBackgroundDark}}"
                                    Padding="{StaticResource AvatarPadding}">
                                <Label Text="S" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextWhite}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <!-- 名称和分类 -->
                            <StackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" Style="{StaticResource LabelPrimary}" />
                                <Label Text="{Binding Category}" Style="{StaticResource LabelTertiary}" />
                            </StackLayout>

                            <!-- 关注按钮 -->
                            <Button Grid.Column="2"
                                    Text="关注"
                                    FontSize="12"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FollowCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding IsFollowedByCurrentUser, Converter={StaticResource InvertedBoolConverter}}" />
                            <Button Grid.Column="2"
                                    Text="已关注"
                                    FontSize="12"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnfollowCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding IsFollowedByCurrentUser}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 加载指示器 -->
        <ActivityIndicator Grid.Row="2" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- 状态消息 -->
        <Label Grid.Row="2" Text="{Binding StatusMessage}" Style="{StaticResource LabelSecondary}" HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>

</ContentPage>
