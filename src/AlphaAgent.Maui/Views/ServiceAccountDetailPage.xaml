<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlphaAgent.Maui.Views.ServiceAccountDetailPage"
             Title="{Binding Name}"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
        <StackLayout Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpacingLarge}">
            <!-- 头像区域 -->
            <Border WidthRequest="80"
                    HeightRequest="80"
                    StrokeShape="RoundRectangle 40"
                    BackgroundColor="{AppThemeBinding Light={StaticResource AvatarBackgroundLight}, Dark={StaticResource AvatarBackgroundDark}}"
                    Padding="{StaticResource AvatarPadding}"
                    HorizontalOptions="Center">
                <Label Text="S"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextWhite}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- 名称和认证 -->
            <StackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="{Binding Name}"
                       FontSize="24"
                       FontAttributes="Bold"
                       Style="{StaticResource LabelPrimary}"
                       HorizontalOptions="Center" />
                <Label Text="{Binding Category}"
                       Style="{StaticResource LabelSecondary}"
                       HorizontalOptions="Center" />
            </StackLayout>

            <!-- 描述 -->
            <Label Text="{Binding Description}"
                   FontSize="14"
                   Style="{StaticResource LabelSecondary}"
                   LineBreakMode="WordWrap"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- 关注者数量 -->
            <Label Text="{Binding FollowerCount, StringFormat='{0} 关注者'}"
                   Style="{StaticResource LabelSecondary}"
                   HorizontalOptions="Center" />

            <!-- 关注/取消关注按钮 -->
            <Button Text="关注"
                    Style="{StaticResource PrimaryActionButton}"
                    Command="{Binding FollowCommand}"
                    IsVisible="{Binding IsFollowed, Converter={StaticResource InvertedBoolConverter}}" />
            <Button Text="已关注"
                    Style="{StaticResource SuccessActionButton}"
                    Command="{Binding UnfollowCommand}"
                    IsVisible="{Binding IsFollowed}" />

            <!-- 欢迎消息卡片 -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                    StrokeShape="RoundRectangle 12"
                    Padding="{StaticResource CardPadding}"
                    IsVisible="{Binding HasWelcomeMessage}">
                <StackLayout Spacing="6">
                    <Label Text="欢迎消息" FontSize="14" FontAttributes="Bold" Style="{StaticResource LabelSecondary}" />
                    <Label Text="{Binding WelcomeMessage}" FontSize="15" Style="{StaticResource LabelPrimary}" LineBreakMode="WordWrap" />
                </StackLayout>
            </Border>

            <!-- 分割线 -->
            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource SeparatorLight}, Dark={StaticResource SeparatorDark}}" />

            <!-- 内容标题 -->
            <Label Text="最新内容" FontSize="18" FontAttributes="Bold" Style="{StaticResource LabelPrimary}" />

            <!-- 内容列表 -->
            <CollectionView ItemsSource="{Binding Posts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,0,0,8">
                            <StackLayout Padding="{StaticResource CardPadding}" Spacing="6">
                                <!-- 置顶标记 -->
                                <Label Text="置顶" FontSize="12" TextColor="Orange" IsVisible="{Binding IsPinned}" />
                                <!-- 标题 -->
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" Style="{StaticResource LabelPrimary}" LineBreakMode="TailTruncation" MaxLines="2" />
                                <!-- 摘要 -->
                                <Label Text="{Binding Summary}" FontSize="14" Style="{StaticResource LabelSecondary}" LineBreakMode="TailTruncation" MaxLines="2" />
                                <!-- 底部信息 -->
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="{StaticResource MessagePadding}">
                                    <Label Grid.Column="0" Text="{Binding ContentType}" Style="{StaticResource LabelTertiary}" />
                                    <Label Grid.Column="2" Text="{Binding PublishedAt, StringFormat='{0:yyyy-MM-dd}'}" Style="{StaticResource LabelTertiary}" />
                                </Grid>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- 状态消息 -->
            <Label Text="{Binding StatusMessage}" Style="{StaticResource LabelSecondary}" HorizontalOptions="Center" />

            <!-- 加载指示器 -->
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" />
        </StackLayout>
    </ScrollView>

</ContentPage>
